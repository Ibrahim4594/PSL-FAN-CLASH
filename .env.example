# PSL Fan Clash — Environment Variables

# Deployer private key (for Hardhat contract deployment ONLY)
PRIVATE_KEY=your_private_key_here

# Claude Sonnet API key (for AI Match Analysis Agent)
# Get your key at: https://console.anthropic.com
# Without this key, the app falls back to local heuristic analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here
